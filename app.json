{
  "expo": {
    "name": "KAIROS",
    "slug": "kairos-assistant",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "kairos",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "updates": {
      "url": "https://u.expo.dev/313ee921-41c4-44c0-a458-46fdb70fcd1e",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kairos.assistant",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "KAIROS benötigt Mikrofonzugriff für Sprachbefehle.",
        "NSSpeechRecognitionUsageDescription": "KAIROS nutzt Spracherkennung für deine Sprachbefehle.",
        "NSLocationWhenInUseUsageDescription": "KAIROS nutzt deinen Standort für Ladenöffnungszeiten in deiner Nähe.",
        "NSUserNotificationUsageDescription": "KAIROS sendet dir intelligente Erinnerungen und Tagesbriefe."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.kairos.assistant",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0E1A",
          "image": "./assets/splash-icon.png",
          "imageWidth": 300
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00D4FF",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "KAIROS nutzt deinen Standort für Ladenöffnungszeiten."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "313ee921-41c4-44c0-a458-46fdb70fcd1e"
      }
    },
    "owner": "kuskus279"
  }
}
